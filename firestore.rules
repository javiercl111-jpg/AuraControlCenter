rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if request is from authenticated user
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper to get admin document (prepares migration to UID while maintaining email compatibility)
    function getAdminData() {
      let uid = request.auth.uid;
      let email = request.auth.token.email;
      let lowerEmail = email != null ? email.lower() : '';
      let hasUidDoc = exists(/databases/$(database)/documents/platform_global_admins/$(uid));
      return hasUidDoc
        ? get(/databases/$(database)/documents/platform_global_admins/$(uid)).data
        : (lowerEmail != ''
            ? get(/databases/$(database)/documents/platform_global_admins/$(lowerEmail)).data
            : {});
    }

    // Check if user has an active admin profile in platform_global_admins (supports both isActive boolean/string and status ACTIVE string)
    function isActiveAdmin() {
      let uid = request.auth.uid;
      let email = request.auth.token.email;
      let lowerEmail = email != null ? email.lower() : '';
      let hasProfile = exists(/databases/$(database)/documents/platform_global_admins/$(uid)) ||
                       (lowerEmail != '' && exists(/databases/$(database)/documents/platform_global_admins/$(lowerEmail)));
      let data = getAdminData();
      return isAuthenticated() && hasProfile && (
        data.isActive == true || 
        data.isActive == 'true' || 
        data.status == 'ACTIVE' || 
        data.status == 'active'
      );
    }

    // Helper to extract role from admin data (supports role, roleCode, and type, normalized to uppercase)
    function getAdminRole() {
      let data = getAdminData();
      let rawRole = data.role != null 
        ? data.role 
        : (data.roleCode != null ? data.roleCode : data.type);
      return rawRole != null ? string(rawRole).upper() : 'VIEWER';
    }

    // Check if user has a specific role
    function hasRole(role) {
      return isActiveAdmin() && getAdminRole() == role;
    }

    // Capabilities checks matching rbacService
    function canReadMarket() {
      return isActiveAdmin() && 
        (getAdminRole() in ['SUPER_ADMIN', 'FOUNDER', 'SALES_DIRECTOR', 'CONSULTANT', 'SALES_ADVISOR', 'VIEWER', 'ADMIN', 'SUPPORT']);
    }

    function canImportMarket() {
      return isActiveAdmin() && 
        (getAdminRole() in ['SUPER_ADMIN', 'FOUNDER', 'SALES_DIRECTOR', 'ADMIN']);
    }

    function canUpdateMarket() {
      return isActiveAdmin() && 
        (getAdminRole() in ['SUPER_ADMIN', 'FOUNDER', 'SALES_DIRECTOR', 'CONSULTANT', 'SALES_ADVISOR', 'ADMIN', 'SUPPORT']);
    }

    function canCreateOrganization() {
      return isActiveAdmin() && 
        (getAdminRole() in ['SUPER_ADMIN', 'FOUNDER', 'SALES_DIRECTOR', 'CONSULTANT', 'ADMIN']);
    }

    // --- Aura Control Center Existing Collections Security ---

    // Platform clients collection permissions
    match /platform_clients/{clientId} {
      allow read, write: if isAuthenticated();
    }

    // Platform tenants collection permissions
    match /platform_tenants/{tenantId} {
      allow read, write: if isAuthenticated();
    }

    // Platform subscriptions collection permissions
    match /platform_subscriptions/{subscriptionId} {
      allow read, write: if isAuthenticated();
    }

    // Platform licenses collection permissions
    match /platform_licenses/{licenseId} {
      allow read, write: if isAuthenticated();
    }

    // Platform provisioning jobs permissions
    match /platform_provisioning_jobs/{jobId} {
      allow read, write: if isAuthenticated();
    }

    // Platform quotes permissions
    match /platform_quotes/{quoteId} {
      allow read, write: if isAuthenticated();
    }

    // Platform commissions permissions
    match /platform_commissions/{commissionId} {
      allow read, write: if isAuthenticated();
    }

    // Platform sales advisors permissions
    match /platform_sales_advisors/{advisorId} {
      allow read, write: if isAuthenticated();
    }

    // Platform global admins permissions
    match /platform_global_admins/{adminEmail} {
      allow read, write: if isAuthenticated();
    }

    // --- Aura Market Intelligence & Consulting Collections Security ---

    // Market Companies
    match /market_companies/{companyId} {
      allow read: if canReadMarket();
      allow create: if canImportMarket();
      allow update: if canUpdateMarket();
      allow delete: if hasRole('SUPER_ADMIN') || hasRole('FOUNDER');
    }

    // Platform Organizations (used by Consulting Center and converted prospects)
    match /platform_organizations/{orgId} {
      allow read: if isAuthenticated();
      allow create: if canCreateOrganization();
      allow update: if isActiveAdmin();
      allow delete: if hasRole('SUPER_ADMIN') || hasRole('FOUNDER');
    }

    // Platform Discovery Requests
    match /platform_discovery_requests/{requestId} {
      allow read, write: if isAuthenticated();
    }
  }
}
